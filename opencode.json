{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "deny",

    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny"
    },

    "glob": "allow",
    "grep": "allow",
    "lsp": "allow",

    "edit": {
      "*": "deny",
      "src/**": "allow",
      "tests/**": "allow"
    },

    "bash": {
      "*": "ask"
	},
    "external_directory": {
      "*": "ask"
    }
  }
}
